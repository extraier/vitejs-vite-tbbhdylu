# Firebase configuration — copy to .env.local and fill in your project values.
# Vite reads VITE_*-prefixed vars at build time.
#
# These are the keys for the production "savetheday-2377a" project.
# They are PUBLIC API keys (Firebase client SDKs need them to identify the
# project) — security is enforced via Firestore/Storage SECURITY RULES, not
# by hiding this config. Do NOT commit your .env.local file.

VITE_FIREBASE_API_KEY=AIzaSy...mEXs
VITE_FIREBASE_AUTH_DOMAIN=savetheday-2377a.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=savetheday-2377a
VITE_FIREBASE_STORAGE_BUCKET=savetheday-2377a.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1076306848030
VITE_FIREBASE_APP_ID=1:1076306848030:web:067794edd31cb2cdb3410f
VITE_FIREBASE_MEASUREMENT_ID=G-LH4S4CEBK1

# NAS photo upload endpoint — replaces Firebase Storage for guest uploads.
# Format: https://<your-tailscale-funnel-host>/upload
VITE_NAS_UPLOAD_URL=
