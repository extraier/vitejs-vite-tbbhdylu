// Wedding App — Firebase Storage Security Rules
// =============================================================================
// Public read for the 6 stock invitation templates so unauthenticated guests
// can render the live preview tile in the InvitationEditor. Writes are gated
// behind the `admin` custom claim (set via Firebase Auth → custom claims).
//
// Deploy with:
//   firebase deploy --only storage
//
// Threat model
// ------------
// 1. Anonymous guests need to fetch /invitation-templates/*.svg to render
//    the design picker. Public read is intentional.
// 2. Only the project admins (3 owner UIDs — see memory) can replace a
//    template. They do this via the `updateTemplate` Cloud Function, which
//    runs as the service account and bypasses these rules. Direct client
//    writes are denied even for admins — the function is the only writer.
// 3. Everything else under this bucket is private (default-deny).
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Admin custom claim gate (mirrors firestore.rules §isAdmin).
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Public read of the stock invitation templates.
    // Writes are denied here — uploads go through the updateTemplate
    // Cloud Function (which uses the service account + Admin SDK and
    // therefore bypasses these rules). This is intentional: it means a
    // misconfigured admin claim on a guest account can't replace a
    // template by hitting Storage directly.
    match /invitation-templates/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny everything else (photos, vendor assets, etc. live
    // under their own owner-scoped paths in a future iteration).
    match /{path=**} {
      allow read, write: if false;
    }
  }
}