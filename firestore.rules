// Wedding App — Firestore Security Rules
// =============================================================================
// Replaces the (missing) test-mode rules. Deploy with:
//   firebase deploy --only firestore:rules
// or via the Firebase Console → Firestore → Rules.
//
// Threat model
// ------------
// 1. Guests arrive via signed QR-code URL: ?token=<HMAC(ownerUid|eventId|guestId|expires)>
// 2. Token is redeemed once → guestLinks/{linkId}.redeemedByUid = auth.uid
// 3. From then on, auth.uid is the ONLY credential. No more raw ownerUid in URL.
//
// 4. Helpers register their own Firebase Auth account (email/password or Google)
// 5. Owner invites helpers via email → Cloud Function creates helpers/{uid} doc
// 6. Helper signs in → reads their own helpers/{auth.uid} doc to learn perms
// 7. Helper accesses owner's data ONLY through perms-checked rules
//
// What each role can do
// ---------------------
// OWNER (auth.uid == ownerUid):
//   • Full CRUD on their own users/{uid}/{events,guests,tasks,photos}
//   • Can read+write their own guestLinks + helpers (to issue invites)
// GUEST (auth.uid == guestLinks/{linkId}.redeemedByUid):
//   • Read the linked event (name, date, tier)
//   • Create photos under that owner (only IF link not expired & not revoked)
//   • Update ONLY their own guest row (hasAttended, hasGifted, giftAmount)
// HELPER (helpers/{auth.uid}.status == 'active' && perms[X] == true):
//   • Per-tab access based on perms flags:
//       canScan / canViewGuestList / canViewBudget / canViewChecklist
//       canViewPhotos / canUploadPhotos / canEditGuests
//       canViewGiftAmount (default false — opt-in per helper)
//   • Cannot see other helpers
//   • Cannot modify the helper doc itself
// VENDOR:
//   • Read /jobRequests (public listings)
//   • Read/write /proposals for jobs they own
//   • Read /vendors/{vendorUid} (any vendor profile, public for browsing)
//   • Write /vendors/{vendorUid} ONLY if auth.uid == vendorUid (own profile)
// EVERYONE ELSE:
//   • No access. Period.
//
// NOTE on appId
// ------------
// We allow read/write under any /artifacts/{appId} segment so the same rules
// work for production, Canvas, and StackBlitz preview environments. The appId
// is not a security boundary — auth + guestLinks + helpers are.
//
// 2026-07-15 — the /vendors/{vendorUid} match block used to be nested
// INSIDE /artifacts/{appId}, which was a bug: the actual Firestore path
// is /vendors/{uid} (NOT under any /artifacts/* prefix), so the rule
// never matched and reads fell through to the catch-all deny. Moved
// the block out to the root level alongside /vendor_events.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ---------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // A guest has redeemed a QR-code link tying them to (owner, event).
    // appId is hardcoded to 'savetheday-production' because Firestore rules
    // cannot reliably resolve $(appId) template variables defined in
    // outer match blocks when referenced from a function definition.
    function hasValidGuestLink(ownerUid, eventId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/artifacts/savetheday-production/users/$(ownerUid)/guestLinks/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/artifacts/savetheday-production/users/$(ownerUid)/guestLinks/$(request.auth.uid)).data.eventId == eventId &&
        get(/databases/$(database)/documents/artifacts/savetheday-production/users/$(ownerUid)/guestLinks/$(request.auth.uid)).data.expiresAt > request.time;
    }

    // A helper has been invited to help with (ownerUid, eventId). Returns the
    // helper doc data if active, otherwise null. Use hasHelperPerm() below
    // for boolean checks.
    function helperDoc(ownerUid) {
      return get(/databases/$(database)/documents/artifacts/savetheday-production/users/$(ownerUid)/helpers/$(request.auth.uid));
    }

    function isActiveHelper(ownerUid) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/artifacts/savetheday-production/users/$(ownerUid)/helpers/$(request.auth.uid)) &&
        helperDoc(ownerUid).data.status == 'active';
    }

    // Returns true if the current user is an active helper AND the named
    // permission flag is true on their helpers doc.
    function hasHelperPerm(ownerUid, perm) {
      return isActiveHelper(ownerUid) &&
        helperDoc(ownerUid).data.perms[perm] == true;
    }

    // A helper is "useful" if they have any view perm. Without at least one,
    // they have no business reading the event doc.
    function hasAnyHelperViewPerm(ownerUid) {
      return isActiveHelper(ownerUid) && (
        helperDoc(ownerUid).data.perms.canScan == true ||
        helperDoc(ownerUid).data.perms.canViewGuestList == true ||
        helperDoc(ownerUid).data.perms.canViewBudget == true ||
        helperDoc(ownerUid).data.perms.canViewChecklist == true ||
        helperDoc(ownerUid).data.perms.canViewPhotos == true ||
        helperDoc(ownerUid).data.perms.canUploadPhotos == true ||
        helperDoc(ownerUid).data.perms.canEditGuests == true
      );
    }

    match /artifacts/{appId} {

      // ---- Owner-scoped data --------------------------------------------

      match /users/{ownerUid} {

        // Events: owner CRUD. Guests + helpers (with at least one view perm) read-only.
        match /events/{eventId} {
          allow read: if isOwner(ownerUid)
            || hasValidGuestLink(ownerUid, eventId)
            || hasAnyHelperViewPerm(ownerUid);
          allow create, update, delete: if isOwner(ownerUid);
        }

        // Guests: owner full CRUD. Helpers may read IF canViewGuestList.
        // Helpers may update IF canScan (only the attendance fields) OR
        // canEditGuests (any field). Guests update only their own row.
        // PersonalGuestPortal.jsx isGuestMode flow uses
        // hasValidGuestLink to fetch the guest's own row so the QR-code
        // recipient can see their seat + photo upload widgets.
        match /guests/{guestDocId} {
          allow read: if isOwner(ownerUid)
            || hasHelperPerm(ownerUid, 'canViewGuestList')
            || hasValidGuestLink(ownerUid, resource.data.eventId);
          allow create, delete: if isOwner(ownerUid);
          // canScan: only allow toggling attendance + audit fields.
          allow update: if isOwner(ownerUid)
            || (hasHelperPerm(ownerUid, 'canScan')
                && request.resource.data.diff(resource.data).affectedKeys()
                     .hasOnly(['hasAttended', 'lastScannedBy', 'lastScannedAt']))
            // canEditGuests: any update allowed (table numbers, names, etc).
            || hasHelperPerm(ownerUid, 'canEditGuests');
          // Guest updates: only their own row, only the safe fields.
          allow update: if isOwner(ownerUid)
            || (
              hasValidGuestLink(ownerUid, resource.data.eventId)
              && resource.data.guestId != null
            );
        }

        // Photos: owner full access. Guests can create (read-only after).
        // Helpers may read IF canViewPhotos, create IF canUploadPhotos.
        // 2026-07-23 — owner was missing from the create allow list.
        // The owner could update/delete (line 173) but couldn't create,
        // which made the photo-upload flow fail when run from the
        // owner's own session. Added isOwner(ownerUid) to the OR.
        match /photos/{photoId} {
          allow read: if isOwner(ownerUid)
            || hasValidGuestLink(ownerUid, resource.data.eventId)
            || hasHelperPerm(ownerUid, 'canViewPhotos');
          allow create: if isSignedIn()
            && (
              isOwner(ownerUid)
              || (hasValidGuestLink(ownerUid, request.resource.data.eventId)
                && request.resource.data.keys().hasAll(['eventId', 'url', 'uploaderId', 'uploaderName', 'createdAt'])
                && request.resource.data.url is string
                && request.resource.data.createdAt is number)
              || (hasHelperPerm(ownerUid, 'canUploadPhotos')
                  && request.resource.data.keys().hasAll(['eventId', 'url', 'uploaderId', 'uploaderName', 'createdAt'])
                  && request.resource.data.url is string
                  && request.resource.data.createdAt is number)
            );
          allow update, delete: if isOwner(ownerUid);
        }

        // Tasks: owner CRUD. Helpers may read IF canViewChecklist (no write).
        // 2026-07-15 — vendors may also read tasks where they are
        // the assigned vendor (assignedVendorUid == auth.uid). The
        // collectionGroup query in App.jsx surfaces these to the
        // vendor dashboard so 主理新人 can hand off work to a vendor
        // they know from Instagram (post-onboarding flow).
        match /tasks/{taskId} {
          allow read: if isOwner(ownerUid)
            || hasHelperPerm(ownerUid, 'canViewChecklist')
            || (isSignedIn() && request.auth.uid == resource.data.assignedVendorUid)
            // 2026-07-19 — helpers assigned via `assignedHelperUid`
            // can read their own tasks too. Same shape as the vendor
            // check above.
            || (isSignedIn() && request.auth.uid == resource.data.assignedHelperUid);
          allow create, delete: if isOwner(ownerUid);
          // 2026-07-17: vendors can write — but ONLY the three status
          // fields, never title/dueDate/cost/etc. Enforced by checking
          // every key in the request is one of those three, OR the
          // caller's uid matches the owner (full-control path).
          allow update: if isOwner(ownerUid)
            || (
              isSignedIn()
              && request.auth.uid == resource.data.assignedVendorUid
              && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['status', 'statusUpdatedAt', 'statusNote'])
            )
            // 2026-07-19 — assigned helpers get the same limited
            // status-update ability as vendors. They cannot rename the
            // task or change due date — just the status fields.
            || (
              isSignedIn()
              && request.auth.uid == resource.data.assignedHelperUid
              && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['status', 'statusUpdatedAt', 'statusNote'])
            );
          // 2026-07-19 — discussion + status-change audit log.
          // Same access model as the parent task: owner /
          // canViewChecklist helper / assigned vendor / assigned
          // helper can read. Owner + assigned vendor + assigned helper
          // can write. Author always has edit+delete on their own
          // comments; statusUpdates are append-only.
          match /comments/{commentId} {
            allow read: if isOwner(ownerUid)
              || hasHelperPerm(ownerUid, 'canViewChecklist')
              || (isSignedIn() && request.auth.uid == resource.data.authorUid)
              || (
                isSignedIn()
                && exists(/databases/$(database)/documents/artifacts/$(appId)/users/$(ownerUid)/tasks/$(taskId))
                && (
                  get(/databases/$(database)/documents/artifacts/$(appId)/users/$(ownerUid)/tasks/$(taskId)).data.assignedVendorUid == request.auth.uid
                  || get(/databases/$(database)/documents/artifacts/$(appId)/users/$(ownerUid)/tasks/$(taskId)).data.assignedHelperUid == request.auth.uid
                )
              );
            // 2026-07-19 — write access: owner / vendor / helper
            // assigned to the parent task. Helper needs `canViewChecklist`
            // perm in their helpers doc to author comments (their helper
            // doc could otherwise be entirely read-only). `parentCommentId`
            // is optional — omit for top-level, set to another
            // comment's id for a reply.
            allow create: if isOwner(ownerUid)
              || (
                isSignedIn()
                && request.resource.data.authorUid == request.auth.uid
                && request.resource.data.keys().hasAll(['authorUid', 'authorRole', 'text', 'createdAt'])
                && request.resource.data.text is string
                && request.resource.data.text.size() > 0
                && request.resource.data.text.size() <= 2000
                && request.resource.data.authorRole in ['owner', 'vendor', 'helper']
                && exists(/databases/$(database)/documents/artifacts/$(appId)/users/$(ownerUid)/tasks/$(taskId))
                && (
                  get(/databases/$(database)/documents/artifacts/$(appId)/users/$(ownerUid)/tasks/$(taskId)).data.assignedVendorUid == request.auth.uid
                  || (
                    get(/databases/$(database)/documents/artifacts/$(appId)/users/$(ownerUid)/tasks/$(taskId)).data.assignedHelperUid == request.auth.uid
                    && hasHelperPerm(ownerUid, 'canViewChecklist')
                  )
                )
              );
            // Author can edit+delete their own; owner (couple) can
            // always delete for moderation.
            allow update, delete: if isOwner(ownerUid)
              || (isSignedIn() && request.auth.uid == resource.data.authorUid);
          }
          // 2026-07-19 — Audit-trail collection for status changes.
          // Append-only: once written, statusUpdates cannot be edited
          // or deleted. The client also writes the change to the
          // parent task's status fields; this collection is the
          // fine-grained timeline (who, when, from→to, optional reason).
          match /statusUpdates/{updateId} {
            allow read: if isOwner(ownerUid)
              || hasHelperPerm(ownerUid, 'canViewChecklist')
              || (
                isSignedIn()
                && exists(/databases/$(database)/documents/artifacts/$(appId)/users/$(ownerUid)/tasks/$(taskId))
                && (
                  get(/databases/$(database)/documents/artifacts/$(appId)/users/$(ownerUid)/tasks/$(taskId)).data.assignedVendorUid == request.auth.uid
                  || get(/databases/$(database)/documents/artifacts/$(appId)/users/$(ownerUid)/tasks/$(taskId)).data.assignedHelperUid == request.auth.uid
                )
              );
            allow create: if (
              isOwner(ownerUid)
              || (
                isSignedIn()
                && request.resource.data.byUid == request.auth.uid
                && request.resource.data.keys().hasAll(['byUid', 'byRole', 'fromStatus', 'toStatus', 'createdAt'])
                && request.resource.data.byRole in ['owner', 'vendor', 'helper']
                && exists(/databases/$(database)/documents/artifacts/$(appId)/users/$(ownerUid)/tasks/$(taskId))
                && (
                  get(/databases/$(database)/documents/artifacts/$(appId)/users/$(ownerUid)/tasks/$(taskId)).data.assignedVendorUid == request.auth.uid
                  || (
                    get(/databases/$(database)/documents/artifacts/$(appId)/users/$(ownerUid)/tasks/$(taskId)).data.assignedHelperUid == request.auth.uid
                    && hasHelperPerm(ownerUid, 'canViewChecklist')
                  )
                )
              )
            );
            // Append-only — never editable.
            allow update, delete: if false;
          }
        }

        // Invitations: owner full CRUD. These are the electronic-invitation
        // templates (templateId, bgUrl, ownerMessage) that sendInvitations
        // callable reads to build the per-guest email/QR. No helper access —
        // inviting guests is an owner-only decision.
        match /invitations/{invitationId} {
          allow read, write: if isOwner(ownerUid);
        }

        // 2026-07-03 — admin-managed invitation template catalog.
        // These are the 6 stock SVG templates (plain / tpl-rose / tpl-jade /
        // tpl-midnight / tpl-blush / tpl-sage) the picker renders on
        // InvitationEditor step 1. Public read so guests can preview tiles
        // without signing in. Writes are admin-only — the in-app UI goes
        // through the `updateTemplate` Cloud Function (which runs as the
        // service account and bypasses these rules), so this admin gate
        // is the second line of defense for direct client writes.
        match /templates/{templateId} {
          allow read: if true;
          allow write: if isAdmin();
        }
        // Cache-buster touched whenever templates/* is updated. Clients
        // watch this doc's updatedAt to know when to re-fetch.
        match /meta/{metaId} {
          allow read: if true;
          allow write: if isAdmin();
        }

        // GuestLinks: owner generates + reads. Guest creates exactly ONE
        // (their own doc, keyed by auth.uid) during QR redemption.
        match /guestLinks/{linkDocId} {
          allow read: if isOwner(ownerUid)
            || (isSignedIn() && request.auth.uid == linkDocId);
          allow create: if isOwner(ownerUid)
            || (
              isSignedIn() && request.auth.uid == linkDocId
              && request.resource.data.keys().hasAll(['ownerUid', 'eventId', 'guestId', 'expiresAt', 'redeemedByUid'])
              && request.resource.data.redeemedByUid == request.auth.uid
              && request.resource.data.expiresAt > request.time
            );
          allow update, delete: if isOwner(ownerUid);
        }

        // Helpers: owner full CRUD on their own helpers collection.
        // Helpers may read ONLY their own doc (to learn their perms).
        // Helpers CANNOT see other helpers (privacy between helpers).
        // Helpers CANNOT write their own doc (only owner can grant/revoke).
        match /helpers/{helperUid} {
          allow read: if isOwner(ownerUid)
            || (isSignedIn() && request.auth.uid == helperUid);
          allow create, update, delete: if isOwner(ownerUid);
        }

        // 2026-07-17 — Pending helper invites (email-pending path).
        // inviteHelper writes here when an owner invites an email that
        // isn't yet tied to a Firebase Auth account. The
        // HelperManager UI reads this in parallel with /helpers and
        // shows them in the "待接受" tab. acceptHelperInvite reads
        // via collectionGroup('pendingInvites') and migrates on first
        // sign-up.
        match /pendingInvites/{email} {
          allow read: if isOwner(ownerUid);
          allow create, update, delete: if isOwner(ownerUid);
        }

        // ScanLog: append-only audit trail of every QR-code scan.
        // Anyone signed-in can write (the helper doing the scan).
        // Only the owner can read the log.
        match /scanLog/{scanId} {
          allow read: if isOwner(ownerUid);
          allow create: if isSignedIn()
            && request.resource.data.keys().hasAll(['guestId', 'helperUid', 'eventId', 'scannedAt'])
            && request.resource.data.helperUid == request.auth.uid;
          allow update, delete: if false;  // immutable
        }

        // 2026-07-15 — VendorContacts: 主理新人 personal address book
        // of vendors they know from outside the platform (Instagram,
        // word of mouth, etc.). Owner-only CRUD; supports optional
        // linkedVendorUid field for contacts whose vendor later signs
        // up and gets auto-linked. Used by MyVendorsPanel + chat.
        match /vendorContacts/{contactId} {
          allow read: if isOwner(ownerUid);
          allow create, update: if isOwner(ownerUid);
          allow delete: if isOwner(ownerUid);
        }

        // ---- Couple's vendor favorites (private) -------------------------
        // A couple pins vendors they're considering into a shortlist at
        // /users/{ownerUid}/favorites/{vendorId}. The doc body is minimal:
        // { vendorId, vendorName, vendorCategory, vendorSnapshot,
        //   createdAt }. Reads + writes owner-only — these never leak to
        // a vendor or to another couple. Used by DiscoverDirectory's
        // heart icon + '❤️ 我的最愛' filter chip.
        match /favorites/{favoriteId} {
          allow read: if isOwner(ownerUid);
          allow create, update: if isOwner(ownerUid);
          allow delete: if isOwner(ownerUid);
        }

        // ---- 2026-07-21: Unlock grants (feature unlocks) ---------------
        // Records of which premium features the user has unlocked and
        // how. Both social-proof path (IG/FB post, referrals, reels)
        // and payment path write here. Frontend reads these to gate
        // UI (e.g. show "premium template" option only when
        // 'custom-template' unlock exists).
        //
        // Reads: owner + admin (admin for support + analytics).
        // Writes: server-side only (Cloud Functions bypass rules via
        // service account). Client write is denied so a malicious
        // couple can't grant themselves premium.
        match /unlocks/{unlockId} {
          allow read: if isOwner(ownerUid) || isAdmin();
          allow create, update, delete: if false;  // server-side only
        }

        // ---- 2026-07-21: Social proofs (IG/FB post submissions) ------
        // Couples submit a public Instagram/Facebook post URL showing
        // they tagged @savetheday.hk. Admin verifies and grants the
        // unlock via adminVerifySocialProof(). Read by owner + admin.
        match /socialProofs/{proofId} {
          allow read: if isOwner(ownerUid) || isAdmin();
          allow create: if isOwner(ownerUid)
            && request.resource.data.keys().hasAll(['unlockType', 'postUrl', 'status', 'createdAt'])
            && request.resource.data.unlockType in ['custom-template', 'permanent-archive']
            && request.resource.data.postUrl is string
            && request.resource.data.status == 'pending'
            && request.resource.data.createdAt is timestamp;
          allow update: if isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'verifiedAt', 'verifiedBy', 'rejectionReason']);
          allow delete: if isAdmin();
        }

        // ---- 2026-07-21: Referral claims (friend signup proof) -------
        // Couple claims a friend used their referral code AND created
        // an event. Admin verifies and grants +500MB storage unlock.
        match /referralClaims/{claimId} {
          allow read: if isOwner(ownerUid) || isAdmin();
          allow create: if isOwner(ownerUid)
            && request.resource.data.keys().hasAll(['unlockType', 'friendUid', 'status', 'createdAt'])
            && request.resource.data.unlockType == 'storage-500mb'
            && request.resource.data.friendUid is string
            && request.resource.data.status == 'pending'
            && request.resource.data.createdAt is timestamp;
          allow update: if isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'verifiedAt', 'verifiedBy', 'rejectionReason']);
          allow delete: if isAdmin();
        }

        // ---- 2026-07-21: Payment receipts (PayMe / FPS manual verify) ---
        // Couple pays via PayMe or FPS, then uploads a screenshot of
        // the receipt. Status flows: pending → approved / rejected.
        // While pending, the unlock is NOT granted yet (admin verifies).
        // Reads: owner (to see their own submissions) + admin (to verify).
        // Writes: create by owner, update by admin only.
        match /paymentReceipts/{receiptId} {
          allow read: if isOwner(ownerUid) || isAdmin();
          allow create: if isOwner(ownerUid)
            && request.resource.data.keys().hasAll([
              'unlockType', 'amount', 'paymentMethod', 'screenshotUrl', 'status', 'createdAt'
            ])
            && request.resource.data.unlockType in [
              'custom-template', 'storage-500mb', 'permanent-archive', 'bundle'
            ]
            && request.resource.data.amount is number
            && request.resource.data.amount > 0
            && request.resource.data.paymentMethod in ['payme', 'fps']
            && request.resource.data.screenshotUrl is string
            && request.resource.data.status == 'pending'
            && request.resource.data.createdAt is timestamp;
          allow update: if isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'verifiedAt', 'verifiedBy', 'rejectionReason']);
          allow delete: if isAdmin();
        }

        // ---- 2026-07-17: Big-day orchestration suite ---------------------
        // Five parallel collections under /users/{ownerUid}:
        //   • rundown   — 大日流程 (time-slot timeline)
        //   • resources — 物資/兄弟姊妹分配清單
        //   • teaCeremony — 敬茶 & 大影相名單 (長輩/新娘/新郎)
        //   • playlist  — 歌單建議 (按儀式 moments 分組)
        //   • checklist_ext — (currently unused — kept for parity with old
        //     docs that may exist in some environments)
        // All four are owner-only CRUD. Helpers are NOT given access
        // here on purpose: 大日 is the couple's master plan, and
        // helpers see only what they need at scan time (guest list +
        // helperPerms.canViewChecklist for tasks).
        match /rundown/{entryId} {
          allow read, write: if isOwner(ownerUid);
        }
        match /resources/{itemId} {
          allow read, write: if isOwner(ownerUid);
        }
        match /teaCeremony/{personId} {
          allow read, write: if isOwner(ownerUid);
        }
        match /playlist/{songId} {
          allow read, write: if isOwner(ownerUid);
        }
      }

      // ---- Public marketplace (vendor discovery) -----------------------

      match /jobRequests/{jobId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.coupleUid == request.auth.uid;
        allow update, delete: if isSignedIn()
          && resource.data.coupleUid == request.auth.uid;
      }

      match /proposals/{proposalId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn()
          && (resource.data.vendorUid == request.auth.uid
              || resource.data.coupleUid == request.auth.uid);
      }

      // 2026-07-20 — vendor ↔ couple chat threads. Lives under
      // /artifacts/{appId}/vendorInquiries/{inquiryId}/ so it can be
      // keyed by a deterministic id (sorted vendorUid + coupleUid)
      // and read by either party. VendorModal's inquiry form calls
      // openInquiry() + sendMessage() from lib/chat.js to create
      // these threads and post the couple's brief as the first
      // message. The vendor sees them in their shared Inbox view.
      match /vendorInquiries/{inquiryId} {
        // Either party can read; admin sees everything for moderation.
        allow read: if isAdmin()
          || (isSignedIn() && (
            resource.data.vendorUid == request.auth.uid
            || resource.data.coupleUid == request.auth.uid
          ));
        // Either party can create — id is deterministic (sorted pair)
        // so a duplicate click is harmless (setDoc merges).
        allow create: if isSignedIn()
          && request.resource.data.keys().hasAll(['vendorUid', 'coupleUid', 'createdAt'])
          && request.resource.data.vendorUid is string
          && request.resource.data.coupleUid is string
          && request.resource.data.createdAt is timestamp
          && (request.resource.data.vendorUid == request.auth.uid
              || request.resource.data.coupleUid == request.auth.uid);
        // Either party can update counters (unread, lastMessageAt, etc).
        allow update: if isSignedIn()
          && (resource.data.vendorUid == request.auth.uid
              || resource.data.coupleUid == request.auth.uid);
        allow delete: if isAdmin()
          || (isSignedIn() && (
            resource.data.vendorUid == request.auth.uid
            || resource.data.coupleUid == request.auth.uid
          ));

        // Messages subcollection. Same auth shape — either party can
        // read + write messages.
        match /messages/{messageId} {
          allow read: if isAdmin()
            || (isSignedIn() && (
              get(/databases/$(database)/documents/artifacts/$(appId)/vendorInquiries/$(inquiryId)).data.vendorUid == request.auth.uid
              || get(/databases/$(database)/documents/artifacts/$(appId)/vendorInquiries/$(inquiryId)).data.coupleUid == request.auth.uid
            ));
          allow create: if isSignedIn()
            && request.resource.data.keys().hasAll(['senderUid', 'senderRole', 'text', 'createdAt'])
            && request.resource.data.senderUid == request.auth.uid
            && request.resource.data.senderRole is string
            && request.resource.data.text is string
            && request.resource.data.text.size() <= 4000
            && request.resource.data.createdAt is timestamp;
          allow update, delete: if false;
        }
      }
    }

    // ---- Vendor directory (root-level, NOT under /artifacts/{appId}) ----
    //
    // The vendor collection lives at /vendors/{uid} (NOT under any
    // artifacts/* prefix) so couples, helpers, and other vendors can
    // query it without knowing the deploy-time appId. This match MUST
    // be outside the /artifacts/{appId} block (was a bug fixed
    // 2026-07-15: previously nested inside, the rule never matched the
    // actual path and reads returned PERMISSION_DENIED from the
    // catch-all).
    match /vendors/{vendorUid} {
      allow read: if true;
      // 2026-07-19 — Vendor CSV import (admin batch) writes here with
      // either: (a) derived ids like 'imp-...', or (b) explicit vendor
      // uid targets. Both should be permitted for admin callers. Owner
      // can still write their own profile.
      allow write: if isAdmin()
        || (isSignedIn() && request.auth.uid == vendorUid);

      // 2026-07-21 — Couples can record an invite request for a vendor
      // who hasn't joined the platform yet. Each request is its own
      // doc under /vendors/{slug}/pendingInvites so admin gets a
      // full audit trail and we don't touch the vendor doc itself.
      // 2026-07-21 (later) — also lets couples bump interestCount on
      // the vendor doc via increment(), which is a safe single-field
      // update. Other vendor fields are still protected by the outer
      // write rule above.
      match /pendingInvites/{inviteId} {
        allow create: if isSignedIn()
          && request.resource.data.keys().hasAll(['email', 'requestedAt', 'status'])
          && request.resource.data.email is string
          && request.resource.data.email.matches('[^@\\s]+@[^@\\s]+\\.[^@\\s]+')
          && request.resource.data.status == 'pending'
          && request.resource.data.requestedAt is timestamp;
        // Admin reads to act on pending invites; vendor reads too
        // (so they see who's waiting for them).
        allow read: if isAdmin() || request.auth.uid == vendorUid;
        // Admin can mark status as 'invited' or 'linked'.
        allow update: if isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'adminUid', 'adminNote', 'invitedAt', 'linkedAt']);
        allow delete: if isAdmin();
      }

      // 2026-07-19 — Audit trail for admin CSV imports. Admin-only
      // create; read for admin only. We deliberately scope audit docs
      // outside /artifacts/* (no per-user isolation needed — they are
      // application-level logs, not user data).
      match /vendorImportLogs/{logId} {
        // Implicit deny on read to anyone but admin.
        allow read: if isAdmin();
        // Anonymous create from browser: only admin (custom-claim `admin`) can create.
        allow create: if isAdmin()
          && request.resource.data.keys().hasAll(['at', 'adminUid', 'fileName'])
          && request.resource.data.at is timestamp;
        allow update, delete: if false;
      }

      // 2026-07-20 — vendor activation audit trail. Every meaningful
      // step of the activation flow (token_issued, email_sent,
      // email_failed, claim_attempt, claim_failed, claim_success,
      // apply_attempt, apply_failed, apply_success) writes here from
      // the cloud function (which uses the service account and bypasses
      // these rules). Admins read this to surface "Activation history"
      // per vendor. Writes from client are denied — only server-side
      // functions may append, otherwise vendors could fake their own
      // activation record.
      match /vendorActivationLogs/{logId} {
        allow read: if isAdmin();
        allow create, update, delete: if false;
      }

      // 2026-07-20 — vendor portfolio image view analytics.
      // Couples open the vendor lightbox to see full-resolution
      // portfolio images; we log one row per lightbox open so the
      // vendor + admin can see which images get the most attention.
      //
      // Read access:
      //   - Admin sees all rows (for moderation + cross-vendor insights)
      //   - Vendor reads only their own rows (where vendorSlug matches
      //     their own vendorUid doc ID). This lets vendors see "which
      //     of my portfolio images is performing best" without seeing
      //     other vendors' analytics.
      //
      // Writes from any signed-in user (couples, vendors previewing,
      // admins). Updates/deletes are denied — analytics are
      // append-only.
      match /vendorImageViews/{viewId} {
        // 2026-07-20 — visibility widened from admin/own-vendor to
        // all signed-in users. Couples need to read this
        // collection for the 商戶指南 popularity sort (count
        // views by vendorSlug). Each row only exposes
        // vendorSlug + count — no PII (image URL is fine, but
        // viewerUid is sensitive so we still gate write-side
        // checks). If we ever need to gate by relationship, do it
        // client-side; for now any signed-in user can see the
        // aggregate.
        allow read: if isAdmin()
          || (isSignedIn() && resource.data.vendorSlug == request.auth.uid)
          || isSignedIn();  // 2026-07-20 — popularity sort needs all rows
        allow create: if isSignedIn()
          && request.resource.data.keys().hasAll(['vendorSlug', 'imageIndex', 'imageUrl', 'viewerUid', 'createdAt'])
          && request.resource.data.vendorSlug is string
          && request.resource.data.imageIndex is int
          && request.resource.data.imageUrl is string
          && request.resource.data.viewerUid is string
          && request.resource.data.createdAt is timestamp
          && request.resource.data.viewerUid == request.auth.uid;
        allow update, delete: if false;
      }

      // 2026-07-20 — vendor direct inquiries. Couples hit the
      // "聯絡商戶" CTA inside VendorModal when the vendor is
      // onboarded (signupStatus === 'claimed'). One inquiry doc
      // per submission, with the couple's name, contact, brief,
      // and the vendor's slug. Vendors read their own inbound
      // inquiries; admin reads everything for moderation.
      //
      // Writes are restricted to signed-in users, and fromUid must
      // match the caller's auth.uid to prevent spoofing. The
      // submitted vendorSlug must equal the caller's target
      // vendorUid — this couples the write to a specific vendor
      // and prevents the couple from claiming to write to arbitrary
      // vendors via a forged vendorSlug.
      match /vendorInquiries/{inquiryId} {
        allow read: if isAdmin()
          || (isSignedIn() && resource.data.vendorSlug == request.auth.uid);
        allow create: if isSignedIn()
          && request.resource.data.keys().hasAll(['vendorSlug', 'vendorName', 'fromContact', 'brief', 'createdAt'])
          && request.resource.data.vendorSlug is string
          && request.resource.data.vendorName is string
          && request.resource.data.fromContact is string
          && request.resource.data.brief is string
          && request.resource.data.brief.size() <= 1000
          && request.resource.data.fromContact.size() <= 200
          && request.resource.data.createdAt is timestamp
          && (request.resource.data.fromUid == null
              || request.resource.data.fromUid == request.auth.uid);
        allow update, delete: if false;
      }

      // 2026-07-17 — Couple reviews/ratings.
      // Public read for browsing.
      // Couples can create/update/delete their own ratings (coupleUid
      // must equal request.auth.uid). Other couples' ratings are
      // immutable.
      match /ratings/{ratingId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.coupleUid == request.auth.uid
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && request.resource.data.review is string
          && request.resource.data.review.size() <= 500;
        allow update, delete: if isSignedIn()
          && resource.data.coupleUid == request.auth.uid;
      }
    }

    // ---- Vendor analytics events (root-level collection) ----------------
    // NOT nested under /artifacts/{appId} because docs live at /vendor_events/*
    // Anyone signed in can write their own tracking events; admin reads
    // require the `admin` custom claim.
    match /vendor_events/{eventId} {
      allow create: if isSignedIn()
        && request.resource.data.type in ['view', 'click']
        && request.resource.data.vendorId is string
        && request.resource.data.vendorId.size() > 0
        && request.resource.data.timestamp == request.time;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ---- Default deny everything else --------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---- Top-level public collections --------------------------------
    // The codebase writes to and reads from /jobRequests at the
    // FIRESTORE TOP LEVEL (collection(db, 'jobRequests') → /jobRequests/*),
    // not /artifacts/{appId}/jobRequests. The matching rule above
    // is under /artifacts/{appId} and never matches the actual path,
    // so direct client reads fall through to the catch-all deny.
    // Mirroring the rule at the top level makes both reads and
    // writes work for signed-in users. Writes additionally require
    // coupleUid == auth.uid so couples can only create posts in
    // their own name.
    match /jobRequests/{jobId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.coupleUid == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.coupleUid == request.auth.uid;
    }
    match /proposals/{proposalId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
        && (resource.data.vendorUid == request.auth.uid
            || resource.data.coupleUid == request.auth.uid);
    }
  }
}