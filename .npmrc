# Use legacy peer-dep resolution to avoid Firebase 10 vs @firebase/rules-unit-testing 5
# peer dep conflict. The two versions are API-compatible in practice — the peer
# warning is overly strict from npm 7+. Setting this globally makes `npm install`
# succeed both locally and on Vercel (which uses npm ci).
#
# Refs:
#   https://docs.npmjs.com/cli/v10/configuring-npm/npmrc
#   https://firebase.google.com/docs/rules/unit-tests
legacy-peer-deps=true
